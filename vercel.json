{
  "version": 2,
  "functions": {
    "api/chat.js": { "maxDuration": 30 },
    "api/bot.js":  { "maxDuration": 30 }
  },
  "headers": [
    {
      "source": "/",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" },
        { "key": "Pragma",        "value": "no-cache" },
        { "key": "Expires",       "value": "0" }
      ]
    }
  ],
  "routes": [
    { "src": "/api/(.*)",      "dest": "/api/$1" },
    { "src": "/sw.js",         "dest": "/sw.js" },
    { "src": "/manifest.json", "dest": "/manifest.json" },
    { "src": "/icons/(.*)",    "dest": "/icons/$1" },
    { "src": "/(.*)",          "dest": "/index.html" }
  ]
}
